{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "if jq -re '.tool_input.file_path' | grep -qE '\\.[jt]sx?$'; then just 2>&1; fi",
            "timeout": 30,
            "async": true
          }
        ]
      }
    ]
  }
}
